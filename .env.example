# Environment variables

# OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=<your key>

# Google Gemini API Key (if using --use-google flag)
GOOGLE_API_KEY=your_google_api_key_here

# Gradio Authentication Users
# Format: "user1:pass1,user2:pass2"
# Leave empty to use default credentials (admin:admin123)
# Example: GRADIO_AUTH_USERS=admin:SecurePass123,demo:demo2024
GRADIO_AUTH_USERS=

# Port for Gradio interface (optional, default: 7860)
PORT=7860
